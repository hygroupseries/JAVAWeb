<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
<servlet>
<!--配置Servlet
    1.servlet类所在的位置
        1) <servlet-name> : 自定义一个名字,代表将要配置的servlet,建议和servlet类名一样
        2) <servlet-class> : 配置上面<servlet-name>代表的Servlet实际路径,从src开始,其实就是类的全路径名
    2.<servlet-mapping>:Servlet类在前端的映射路径
        1)<servlet-name>: 自定义的Servlet的名,对应<servlet>的<servlet-name>
        2)<url-pattern>: 上述Servlet在前端路径中的映射,拼接到url的web应用后面
    -->
    <servlet-name>HelloServlet</servlet-name>
    <servlet-class>javaweb04.HelloServerlet</servlet-class>
</servlet>
    <servlet-mapping>
        <servlet-name>HelloServlet</servlet-name>
        <url-pattern>/4/hello</url-pattern>
    </servlet-mapping>
</web-app>