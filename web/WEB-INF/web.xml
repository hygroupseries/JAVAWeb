<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

<!--    配置Servlet
        1.<servlet> - 配置servlet类所在的位置
            1) <servlet-name> :
                    a.自定义一个名字（代表是将要配置的这个servlet），
                    建议和Servlet类名一致
            2)<servlet-class> ：
                    配置上面<servlet-name>所代表的Serlvet类的实际路径
                    从src(根目录)开始
                    其实就是类的全路径名
        2.<servlet-mapping>：配置Servlet类在前端的映射路径
            1)<servlet-name>：
                    自定义的Serlvet的名 —— 对应1-1)-a
            2)<url-pattern>:
                    上述Servlet在前端路径中的映射
                    拼接到url的web应用后面
-->
    <servlet>
        <servlet-name>HelloServlet</servlet-name>
        <servlet-class>javaweb04.HelloServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>HelloServlet</servlet-name>
        <url-pattern>/4/hello</url-pattern>
    </servlet-mapping>
    <!--<servlet-mapping>
        <servlet-name>HelloServlet</servlet-name>
        <url-pattern>/*</url-pattern>
    </servlet-mapping>-->


